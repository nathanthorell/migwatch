# Azure AD app client ID for interactive browser auth (ActiveDirectoryInteractive)
# This is Microsoft's well-known Azure CLI app ID and works for most organizations
AZURE_CLIENT_ID=04b07795-8ddb-461a-bbee-02f9e1bf7b46

# SQL Server - SQL auth
DEV_DSN=sqlserver://myuser:mypass@myserver?database=mydb
TEST_DSN=sqlserver://myuser:mypass@myserver?database=testdb

# SQL Server - Entra (az login token)
DEV_AZ_DSN=sqlserver://myserver.database.windows.net?database=mydb&fedauth=ActiveDirectoryAzCli

# SQL Server - Entra interactive (browser popup)
DEV_AZI_DSN=sqlserver://myserver.database.windows.net?database=mydb&fedauth=ActiveDirectoryInteractive

# SQL Server - Entra default credential chain
DEV_AZD_DSN=sqlserver://myserver.database.windows.net?database=mydb&fedauth=ActiveDirectoryDefault

# PostgreSQL - password auth
DEV_PG_DSN=postgres://myuser:mypass@myserver:5432/mydb?sslmode=disable

# PostgreSQL - Entra default credential chain (Azure Flexible Server)
DEV_PG_AZD_DSN=postgres://myuser%40example.com@myserver.postgres.database.azure.com/mydb?sslmode=require&fedauth=ActiveDirectoryDefault
